# Borderhaus Website — Umgebungsvariablen
# Kopiere diese Datei nach .env.local und fülle die Werte. Nichts hiervon ist
# zwingend für den Build: ohne Konfiguration läuft die Seite, Leads werden dann
# nur geloggt und Analytics/Sanity sind aus.

# --- Domain & Kontakt ---
NEXT_PUBLIC_SITE_URL=https://borderhaus.com
NEXT_PUBLIC_CONTACT_EMAIL=hallo@borderhaus.com

# --- Lead-Mail (Resend) ---
# RESEND_API_KEY=re_xxx
# LEAD_INBOX=leads@borderhaus.com
# LEAD_FROM=Borderhaus <leads@borderhaus.com>

# --- CRM Webhook (optional, generisch) ---
# CRM_WEBHOOK_URL=https://example.com/webhook

# --- Zoho CRM (Leads, OAuth Self-Client, EU-Domain) ---
# ZOHO_CLIENT_ID=1000.xxxxx
# ZOHO_CLIENT_SECRET=xxxxx
# ZOHO_REFRESH_TOKEN=1000.xxxxx.yyyyy
# ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.eu
# ZOHO_API_DOMAIN=https://www.zohoapis.eu

# --- Book a Call (Google Termin-Kalender) ---
# NEXT_PUBLIC_BOOKING_URL=https://calendar.app.google/Mq3q8r8ab3BWM2bW7

# --- Spam-Schutz: Cloudflare Turnstile ---
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# --- Analytics: Plausible (cookielos) ---
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=borderhaus.com
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# --- Knowledge Base: Sanity ---
# NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxx
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
